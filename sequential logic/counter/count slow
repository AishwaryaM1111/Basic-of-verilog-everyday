module top_module (
    input clk,
    input slowena,
    input reset,
    output [3:0] q);
    
    reg [3:0]cnt;
    always @(posedge clk) begin
        if(reset) begin
            cnt<=0;
        end
            else if (slowena) begin
                if(cnt==4'b1001)
                    cnt<=0;
                else 
                    cnt<=cnt+1;
        end
    end
    assign q=cnt;
           
        
endmodule
